<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- SMS Permissions -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.WRITE_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_MMS" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- Contact lookup -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Network for API forwarding -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Vibration for notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Required to be default SMS app -->
    <uses-permission android:name="android.permission.BROADCAST_WAP_PUSH" />
    <uses-permission android:name="android.permission.SEND_RESPOND_VIA_MESSAGE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SMSApp"
        android:name=".SMSApplication">

        <!-- ══════════════════════════════════════════ -->
        <!-- Activities                                  -->
        <!-- ══════════════════════════════════════════ -->

        <!-- Main conversation list - also the SEND intent handler (required for default SMS app) -->
        <activity
            android:name=".ui.ConversationListActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Required for default SMS app: handle plain-text shares -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <data android:mimeType="text/plain" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- Handle image shares -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <data android:mimeType="image/*" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Thread / message view -->
        <activity
            android:name=".ui.MessageThreadActivity"
            android:exported="false"
            android:windowSoftInputMode="stateHidden|adjustResize" />

        <!-- New message / compose -->
        <activity
            android:name=".ui.ComposeActivity"
            android:exported="true"
            android:windowSoftInputMode="stateVisible|adjustResize">
            <!-- Required for default SMS app: handle SENDTO intents -->
            <intent-filter>
                <action android:name="android.intent.action.SENDTO" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Settings -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false" />

        <!-- ══════════════════════════════════════════ -->
        <!-- Receivers                                   -->
        <!-- ══════════════════════════════════════════ -->

        <!-- Incoming SMS receiver -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_DELIVER" />
            </intent-filter>
        </receiver>

        <!-- MMS receiver (required for default SMS app) -->
        <receiver
            android:name=".receiver.MmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_WAP_PUSH">
            <intent-filter>
                <action android:name="android.provider.Telephony.WAP_PUSH_DELIVER" />
                <data android:mimeType="application/vnd.wap.mms-message" />
            </intent-filter>
        </receiver>

        <!-- ══════════════════════════════════════════ -->
        <!-- Services                                    -->
        <!-- ══════════════════════════════════════════ -->

        <!-- HeadsUp helper (no intent-filter needed) -->
        <service
            android:name=".ui.HeadsUpService"
            android:exported="false" />

        <!--
            REQUIRED for default SMS app eligibility.
            Android checks that a Service handling RESPOND_VIA_MESSAGE exists
            before granting the default SMS role.
        -->
        <service
            android:name=".service.RespondViaMessageService"
            android:exported="true"
            android:permission="android.permission.SEND_RESPOND_VIA_MESSAGE">
            <intent-filter>
                <action android:name="android.intent.action.RESPOND_VIA_MESSAGE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="sms" />
                <data android:scheme="smsto" />
                <data android:scheme="mms" />
                <data android:scheme="mmsto" />
            </intent-filter>
        </service>

        <!-- ══════════════════════════════════════════ -->
        <!-- Providers                                   -->
        <!-- ══════════════════════════════════════════ -->

        <!-- WorkManager initializer -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup" />
        </provider>

    </application>

</manifest>
