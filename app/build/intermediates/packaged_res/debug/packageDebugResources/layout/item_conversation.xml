<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:paddingHorizontal="16dp"
    android:paddingVertical="14dp">

    <!-- Avatar circle with contact initial -->
    <TextView
        android:id="@+id/view_avatar"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_avatar"
        android:gravity="center"
        android:textColor="@color/avatar_text"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <!-- Important dot (red indicator on avatar) -->
    <View
        android:id="@+id/view_important_dot"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:background="@drawable/bg_important_dot"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="@id/view_avatar"
        app:layout_constraintTop_toTopOf="@id/view_avatar" />

    <!-- Contact name -->
    <TextView
        android:id="@+id/tv_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceTitleMedium"
        app:layout_constraintEnd_toStartOf="@id/tv_time"
        app:layout_constraintStart_toEndOf="@id/view_avatar"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Timestamp -->
    <TextView
        android:id="@+id/tv_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_name"
        app:layout_constraintBottom_toBottomOf="@id/tv_name" />

    <!-- Message snippet -->
    <TextView
        android:id="@+id/tv_snippet"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:textColor="?attr/colorOnSurfaceVariant"
        app:layout_constraintEnd_toStartOf="@id/tv_unread_count"
        app:layout_constraintStart_toEndOf="@id/view_avatar"
        app:layout_constraintTop_toBottomOf="@id/tv_name" />

    <!-- Unread count pill badge -->
    <TextView
        android:id="@+id/tv_unread_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="22dp"
        android:background="@drawable/bg_badge"
        android:gravity="center"
        android:paddingHorizontal="6dp"
        android:paddingVertical="3dp"
        android:textAppearance="?attr/textAppearanceLabelSmall"
        android:textColor="@android:color/white"
        android:textSize="11sp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_time" />

    <!-- API Tag chip -->
    <com.google.android.material.chip.Chip
        android:id="@+id/chip_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="4dp"
        android:textSize="11sp"
        android:visibility="gone"
        style="@style/Widget.Material3.Chip.Suggestion"
        app:layout_constraintStart_toEndOf="@id/view_avatar"
        app:layout_constraintTop_toBottomOf="@id/tv_snippet" />

</androidx.constraintlayout.widget.ConstraintLayout>
